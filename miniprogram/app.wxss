/* app.wxss — 全局基础样式
   设计 Token 统一在此定义，各页面通过类名复用
   ================================================================ */

/* ── 全局重置 ──────────────────────────────────────────────────── */
page {
  background-color: #F4F6F8;
  font-family:
    -apple-system, "PingFang SC", "Helvetica Neue",
    "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #1A1A2E;
  line-height: 1.6;
  -webkit-tap-highlight-color: transparent;
  box-sizing: border-box;
}

/* box-sizing reset via page-level selector for miniprogram compatibility */
view, text, image, input, textarea, button, scroll-view, swiper, swiper-item {
  box-sizing: border-box;
}

/* ── 通用工具类 ─────────────────────────────────────────────────── */

/* 文字颜色 */
.text-primary   { color: #00C7B2; }
.text-accent    { color: #FF8C69; }
.text-info      { color: #4A90E2; }
.text-success   { color: #2ECC71; }
.text-warning   { color: #FFB347; }
.text-danger    { color: #E53935; }
.text-main      { color: #1A1A2E; }
.text-sub       { color: #5A6478; }
.text-hint      { color: #A0A8B5; }

/* 字重 */
.fw-400 { font-weight: 400; }
.fw-500 { font-weight: 500; }
.fw-600 { font-weight: 600; }
.fw-700 { font-weight: 700; }
.fw-800 { font-weight: 800; }

/* 卡片通用阴影 */
.shadow-sm {
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.shadow-md {
  box-shadow:
    0 4rpx 24rpx rgba(0, 199, 178, 0.10),
    0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}
.shadow-lg {
  box-shadow:
    0 8rpx 32rpx rgba(0, 199, 178, 0.15),
    0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 卡片基础 */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow:
    0 4rpx 24rpx rgba(0, 199, 178, 0.10),
    0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

/* 主按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  border-radius: 100rpx;
  background: linear-gradient(135deg, #00C7B2, #00A896);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 199, 178, 0.4);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 次级按钮 */
.btn-outline {
  width: 100%;
  height: 88rpx;
  border-radius: 100rpx;
  background: transparent;
  border: 2rpx solid #00C7B2;
  color: #00C7B2;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Badge 通用 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.badge-primary { background: #E6FAF8; color: #00A896; }
.badge-warning { background: #FFF1EC; color: #FF6B4A; }
.badge-danger  { background: #FDECEA; color: #E53935; }
.badge-info    { background: #EBF3FF; color: #3478C8; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #F0F3F6;
  margin: 16rpx 0;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-icon  { font-size: 80rpx; }
.empty-text  { font-size: 26rpx; color: #A0A8B5; }
