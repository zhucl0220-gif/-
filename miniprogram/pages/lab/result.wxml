<view class="page">
  <view class="header">
    <text class="title">化验结果详情</text>
  </view>
  <view wx:for="{{items}}" wx:key="name" class="item-row">
    <text class="item-name">{{item.name}}</text>
    <view class="item-right">
      <text class="item-val {{item.is_abnormal ? 'abnormal' : ''}}">{{item.value}} {{item.unit}}</text>
      <text class="item-ref">参考：{{item.ref_range}}</text>
    </view>
  </view>
</view>
