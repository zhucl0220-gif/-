.page { min-height: 100vh; background: #F4F6F8; padding-bottom: 120rpx; }
.header { background: #00C7B2; padding: 40rpx 32rpx 48rpx; }
.header-title { display: block; color: #fff; font-size: 40rpx; font-weight: 600; }
.header-sub { display: block; color: rgba(255,255,255,0.8); font-size: 26rpx; margin-top: 8rpx; }
.upload-area { margin: 32rpx; background: #fff; border-radius: 16rpx; min-height: 320rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2rpx dashed #D0D7E2; }
.upload-icon { width: 96rpx; height: 96rpx; opacity: 0.4; }
.upload-text { color: #333; font-size: 30rpx; margin-top: 20rpx; font-weight: 500; }
.upload-hint { color: #999; font-size: 24rpx; margin-top: 8rpx; }
.preview-img { width: 100%; height: 400rpx; border-radius: 16rpx; }
.reselect-btn { margin-top: 16rpx; color: #00C7B2; font-size: 28rpx; }
.section { margin: 0 32rpx 24rpx; background: #fff; border-radius: 16rpx; padding: 28rpx; }
.section-title { font-size: 28rpx; color: #666; display: block; margin-bottom: 20rpx; }
.type-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.type-chip { padding: 12rpx 28rpx; border-radius: 40rpx; border: 2rpx solid #E0E6EF; font-size: 26rpx; color: #555; background: #F8FAFB; }
.type-chip.active { background: #E6FAF8; border-color: #00C7B2; color: #00C7B2; font-weight: 500; }
.result-card { margin: 0 32rpx 24rpx; background: #fff; border-radius: 16rpx; padding: 28rpx; }
.result-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.result-title { font-size: 30rpx; font-weight: 600; color: #222; }
.risk-tag { padding: 6rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; }
.risk-tag.medium { background: #FFF3CD; color: #B07D00; }
.risk-tag.high { background: #FDECEA; color: #C0392B; }
.risk-tag.low { background: #E6FAF0; color: #1A8A50; }
.result-summary { font-size: 28rpx; color: #444; line-height: 1.7; margin-bottom: 20rpx; }
.rec-item { display: flex; margin-bottom: 12rpx; }
.rec-dot { color: #00C7B2; font-size: 28rpx; margin-right: 12rpx; margin-top: 2rpx; }
.rec-text { font-size: 26rpx; color: #555; flex: 1; line-height: 1.6; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 24rpx 32rpx; border-top: 1rpx solid #F0F0F0; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.submit-btn { background: #00C7B2; color: #fff; font-size: 32rpx; border-radius: 12rpx; font-weight: 500; }
.submit-btn.loading { opacity: 0.6; }
