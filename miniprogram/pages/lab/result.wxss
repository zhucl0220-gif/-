.page { min-height: 100vh; background: #F4F6F8; padding: 32rpx; }
.header { margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: 600; color: #222; display: block; }
.item-row { background: #fff; border-radius: 12rpx; padding: 24rpx 28rpx; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.item-name { font-size: 28rpx; color: #333; flex: 1; }
.item-right { text-align: right; }
.item-val { font-size: 32rpx; font-weight: 600; color: #333; display: block; }
.item-val.abnormal { color: #E74C3C; }
.item-ref { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
