.page { min-height: 100vh; background: #F4F6F8; padding-bottom: 120rpx; }
.header { background: #00C7B2; padding: 40rpx 32rpx 48rpx; }
.title { color: #fff; font-size: 40rpx; font-weight: 600; display: block; }
.sub { color: rgba(255, 255, 255, 0.8); font-size: 26rpx; display: block; margin-top: 8rpx; }
.q-card { margin: 24rpx 32rpx 0; background: #fff; border-radius: 16rpx; padding: 28rpx; }
.q-text { font-size: 30rpx; color: #222; font-weight: 500; display: block; margin-bottom: 20rpx; line-height: 1.6; }
.q-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.option { padding: 14rpx 28rpx; border-radius: 40rpx; border: 2rpx solid #E0E6EF; font-size: 26rpx; color: #555; }
.option.selected { background: #E6FAF8; border-color: #00C7B2; color: #00C7B2; font-weight: 500; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #F0F0F0; }
.submit-btn { background: #00C7B2; color: #fff; font-size: 32rpx; border-radius: 12rpx; font-weight: 500; }
