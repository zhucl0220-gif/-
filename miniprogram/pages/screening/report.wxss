.page { min-height: 100vh; background: #F4F6F8; padding: 32rpx; }
.score-card { background: #00C7B2; border-radius: 20rpx; padding: 48rpx; text-align: center; }
.score-label { display: block; color: rgba(255, 255, 255, 0.8); font-size: 28rpx; }
.score-val { display: block; color: #fff; font-size: 100rpx; font-weight: 700; line-height: 1.1; }
.score-unit { display: block; color: rgba(255, 255, 255, 0.7); font-size: 28rpx; }
.risk-level { display: block; color: #fff; font-size: 36rpx; font-weight: 600; margin-top: 16rpx; }
.section { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-top: 24rpx; }
.section-title { display: block; font-size: 28rpx; color: #888; margin-bottom: 16rpx; font-weight: 500; }
.rec-text { display: block; font-size: 28rpx; color: #444; line-height: 1.8; }
