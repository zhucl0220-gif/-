.page { min-height: 100vh; background: #F4F6F8; padding: 24rpx 32rpx; }
.header { margin-bottom: 24rpx; }
.title { font-size: 40rpx; font-weight: 600; color: #222; display: block; }
.msg-item { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; display: flex; align-items: flex-start; gap: 24rpx; }
.msg-icon-wrap { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #E6FAF8; flex-shrink: 0; }
.msg-icon { font-size: 36rpx; }
.msg-body { flex: 1; }
.msg-title { display: block; font-size: 30rpx; font-weight: 600; color: #222; margin-bottom: 10rpx; }
.msg-text { display: block; font-size: 26rpx; color: #666; line-height: 1.6; margin-bottom: 12rpx; }
.msg-time { display: block; font-size: 22rpx; color: #aaa; }
