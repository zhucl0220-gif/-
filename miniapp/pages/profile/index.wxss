/* pages/profile/index.wxss */
page { background: #F8F9FA; }
.page-root { min-height: 100vh; background: #F8F9FA; padding-bottom: 60rpx; }
.mx24 { margin-left: 24rpx; margin-right: 24rpx; }
.mt24 { margin-top: 24rpx; }
.mt16 { margin-top: 16rpx; }
.mt20 { margin-top: 20rpx; }
.mt40 { margin-top: 40rpx; }

/* ══ 就诊卡 ══ */
.card-bg {
  padding: 24rpx 24rpx 0;
  background: #F8F9FA;
}
.id-card {
  background: linear-gradient(135deg, #00C7B2 0%, #009e8e 55%, #007a6d 100%);
  border-radius: 28rpx;
  padding: 32rpx 36rpx 28rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(0,199,178,0.30);
  min-height: 220rpx;
}
.card-circle-1 {
  position: absolute; width: 260rpx; height: 260rpx; border-radius: 50%;
  background: rgba(255,255,255,0.07);
  right: -60rpx; top: -80rpx;
}
.card-circle-2 {
  position: absolute; width: 180rpx; height: 180rpx; border-radius: 50%;
  background: rgba(255,255,255,0.05);
  right: 60rpx; bottom: -60rpx;
}
.card-top-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24rpx;
}
.card-hospital { display: flex; align-items: center; gap: 8rpx; }
.hospital-icon { font-size: 28rpx; }
.hospital-name { font-size: 22rpx; color: rgba(255,255,255,0.85); font-weight: 500; }
.card-label { font-size: 20rpx; color: rgba(255,255,255,0.6); letter-spacing: 4rpx; }
.card-mid-row {
  display: flex; align-items: center; gap: 20rpx;
  margin-bottom: 24rpx;
}
/* 金属芯片 */
.chip-wrap { flex-shrink: 0; }
.chip {
  width: 56rpx; height: 42rpx; border-radius: 8rpx;
  background: linear-gradient(135deg, #FFE066 0%, #FFB800 50%, #E09600 100%);
  box-shadow: inset 0 2rpx 4rpx rgba(255,255,255,0.4), 0 2rpx 6rpx rgba(0,0,0,0.25);
  position: relative;
}
.chip::before {
  content: ''; position: absolute;
  left: 12rpx; right: 12rpx; top: 12rpx; bottom: 12rpx;
  border: 2rpx solid rgba(200,140,0,0.5); border-radius: 4rpx;
}
.card-patient-info { flex: 1; }
.card-patient-name {
  font-size: 38rpx; font-weight: 700; color: #fff;
  display: block; letter-spacing: 2rpx;
}
.card-patient-sub {
  font-size: 22rpx; color: rgba(255,255,255,0.75);
  display: block; margin-top: 4rpx;
}
.edit-btn-card {
  padding: 10rpx 24rpx; border-radius: 28rpx;
  background: rgba(255,255,255,0.18);
  color: #fff; font-size: 24rpx; flex-shrink: 0;
  border: 1rpx solid rgba(255,255,255,0.3);
}
.card-bottom-row {
  display: flex; align-items: center; gap: 14rpx;
}
.card-tag {
  font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 18rpx;
  background: rgba(255,255,255,0.20); color: #fff;
  border: 1rpx solid rgba(255,255,255,0.25);
}
.risk-tag-card.risk-high { background: rgba(255,77,79,0.25); border-color: rgba(255,77,79,0.5); }
.risk-tag-card.risk-medium { background: rgba(250,173,20,0.25); border-color: rgba(250,173,20,0.5); }
.card-id { font-size: 20rpx; color: rgba(255,255,255,0.55); margin-left: auto; }

/* ══ Tab ══ */
.tab-bar {
  display: flex; background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
  margin-top: 16rpx;
}
.tab-item { flex: 1; text-align: center; padding: 28rpx 0; font-size: 28rpx; color: #888; }
.tab-active { color: #00C7B2; border-bottom: 4rpx solid #00C7B2; font-weight: 700; }
.tab-body { height: calc(100vh - 460rpx); }

/* ══ 卡片/分节 ══ */
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.section-hd { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.section-bar { display: block; width: 6rpx; height: 32rpx; background: #00C7B2; border-radius: 4rpx; flex-shrink: 0; }
.card-title { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.card-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }

/* ══ 档案表单 ══ */
.info-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0; border-top: 2rpx solid #f5f5f5;
}
.info-label { font-size: 26rpx; color: #888; width: 160rpx; flex-shrink: 0; }
.info-val { font-size: 28rpx; color: #333; font-weight: 500; }
.info-val-edit { font-size: 28rpx; color: #00C7B2; }
.info-input {
  width: 320rpx; border-bottom: 2rpx solid #e8e8e8;
  font-size: 28rpx; color: #333; padding: 4rpx 0; text-align: right;
}
.action-row { display: flex; gap: 20rpx; }
.btn-primary {
  flex: 2; height: 88rpx; border-radius: 44rpx;
  background: linear-gradient(90deg, #00C7B2, #009e8e);
  color: #fff; font-size: 30rpx; font-weight: 700; border: none;
}
.btn-secondary {
  flex: 1; height: 88rpx; border-radius: 44rpx;
  background: #F8F9FA; color: #666; font-size: 30rpx; border: none;
}
.empty-tip { text-align: center; font-size: 28rpx; color: #bbb; padding: 60rpx 0; }

/* ══ 报告列表 ══ */
.report-item { }
.report-item-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12rpx; }
.report-title { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.report-date  { font-size: 24rpx; color: #aaa; margin-top: 4rpx; }
.report-risk  { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 16rpx; font-weight: 600; }
.risk-low    { background: #f6ffed; color: #52c41a; }
.risk-medium { background: #fffbe6; color: #faad14; }
.risk-high   { background: #fff2f0; color: #ff4d4f; }
.report-summary { font-size: 26rpx; color: #666; line-height: 1.6; }
.report-footer  { margin-top: 12rpx; text-align: right; }
.report-arrow   { font-size: 24rpx; color: #00C7B2; }

/* ══ 趋势图 ══ */
.chart-legend-row { display: flex; gap: 24rpx; margin-bottom: 16rpx; }
.legend-item     { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #666; }
.legend-line     { width: 40rpx; height: 4rpx; border-radius: 2rpx; }
.alb-line        { background: #00C7B2; }
.wt-line         { background: #FA8C16; }
.legend-band     { width: 28rpx; height: 14rpx; background: rgba(0,199,178,0.15); border-radius: 4rpx; border: 1rpx solid #00C7B2; }
.canvas-wrap     { position: relative; width: 100%; height: 400rpx; }
.dual-canvas     { width: 100%; height: 400rpx; display: block; }
.chart-empty     {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #bbb;
}

/* 统计摘要 */
.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.stat-card { background: #F8F9FA; border-radius: 16rpx; padding: 20rpx; display: flex; flex-direction: column; gap: 6rpx; }
.stat-label { font-size: 22rpx; color: #888; }
.stat-val   { font-size: 36rpx; font-weight: 700; }
.stat-unit  { font-size: 20rpx; color: #aaa; }
.stat-ref   { font-size: 20rpx; color: #bbb; }
.text-success { color: #52c41a; }
.text-warning { color: #faad14; }
.text-danger  { color: #ff4d4f; }

/* 体重条形 */
.weight-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 14rpx; }
.weight-date { font-size: 24rpx; color: #888; width: 80rpx; flex-shrink: 0; }
.weight-bar-bg { flex: 1; height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.weight-bar-fill { height: 100%; background: linear-gradient(90deg, #00C7B2, #009e8e); border-radius: 8rpx; }
.weight-val { font-size: 24rpx; color: #333; font-weight: 600; width: 80rpx; text-align: right; flex-shrink: 0; }