/* pages/home/index.wxss — 阿福管家风 */

.root {
  min-height: 100vh;
  background: #F8F9FA;
  padding-bottom: 160rpx;
}

/* ── 顶部 Banner ────────────────────────────────────────── */
.header {
  background: linear-gradient(135deg, #00C7B2 0%, #00a898 100%);
  padding: 60rpx 36rpx 52rpx;
}
.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}
/* MP-06: 大字号问候语 */
.greeting {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
  line-height: 1.2;
}
.date-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 8rpx;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
}

/* MP-08: 风险标识片 */
.risk-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 700;
  background: rgba(255,255,255,0.2);
  color: #fff;
  align-self: flex-start;
}
.risk-chip-low    { background: rgba(82,196,26,0.2);  }
.risk-chip-medium { background: rgba(255,153,0,0.25); }
.risk-chip-high   { background: rgba(255,77,79,0.25); }
.risk-icon  { font-size: 28rpx; }
.risk-text  { font-size: 26rpx; font-weight: 700; }
.risk-question {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
}

/* ── 风险弹窗 ──────────────────────────────────────────── */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 40rpx;
}
.risk-pop {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}
.risk-pop-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 32rpx;
}
.risk-pop-low    { background: #F6FFF0; }
.risk-pop-medium { background: #FFFBF0; }
.risk-pop-high   { background: #FFF5F5; }
.risk-pop-icon  { font-size: 40rpx; }
.risk-pop-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.risk-pop-body {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  padding: 0 32rpx 28rpx;
}
.risk-pop-btn {
  display: block;
  margin: 0 32rpx 28rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #00C7B2;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  line-height: 80rpx;
}

/* ── 通用卡片 ────────────────────────────────────────────── */
.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* ── MP-07: 阶段进度卡 ───────────────────────────────────── */
.phase-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}
.phase-tag-pre   { background: #E6FBF9; color: #00C7B2; }
.phase-tag-inhos { background: #FFF7E6; color: #FA8C16; }
.phase-tag-post  { background: #F5F0FF; color: #7B61FF; }
.phase-tag-home  { background: #F6FFED; color: #52C41A; }

/* 进度条 */
.phase-bar-outer {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
}
.phase-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #00C7B2 0%, #52C41A 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* 节点 */
.phase-nodes {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.phase-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.phase-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #E8E8E8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}
.phase-node.done   .phase-dot { background: #00C7B2; }
.phase-node.active .phase-dot { background: #00C7B2; box-shadow: 0 0 0 6rpx rgba(0,199,178,0.2); }
.phase-check { font-size: 20rpx; color: #fff; font-weight: 700; }
.phase-pulse {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
}
.phase-label {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  line-height: 1.3;
}
.phase-node.done   .phase-label { color: #00C7B2; }
.phase-node.active .phase-label { color: #00C7B2; font-weight: 600; }
.phase-tip-bar {
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
  background: #F0FBF9;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #00C7B2;
}

/* ── MP-09: 近 7 日摘要 ─────────────────────────────────────── */
.stat-row {
  display: flex;
  align-items: center;
}
.stat-item { flex: 1; text-align: center; }
.stat-val {
  font-size: 56rpx;
  font-weight: 800;
  color: #1A1A1A;
  line-height: 1.1;
  display: inline-block;
}
.stat-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
  display: inline-block;
  vertical-align: bottom;
  margin-bottom: 4rpx;
}
.stat-key {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}
.stat-sep {
  width: 2rpx;
  height: 72rpx;
  background: #F0F0F0;
}
.stat-green  { color: #00C7B2; }
.stat-danger { color: #FF6B6B; }
.stat-warning{ color: #FF9900; }
.stat-success{ color: #52C41A; }

/* ── 快捷功能入口 ────────────────────────────────────────── */
.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 0;
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  padding: 28rpx 8rpx;
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.qi-teal   { background: #E6FBF9; }
.qi-green  { background: #F6FFED; }
.qi-orange { background: #FFF7E6; }
.qi-purple { background: #F5F0FF; }
.quick-label { font-size: 22rpx; color: #555; }

/* ── 档案提示卡 ────────────────────────────────────────────── */
.prompt-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-left: 6rpx solid #FF9900;
}
.prompt-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}
.prompt-sub {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}
.prompt-arrow {
  font-size: 44rpx;
  color: #ccc;
}

/* ── 悬浮 AI 按钮 ──────────────────────────────────────────── */
.fab-ai {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00C7B2 0%, #00a898 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,199,178,0.45);
  z-index: 100;
}
.fab-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
}

/* 顶部栏 */
.home-header {
  background: linear-gradient(90deg, #00C7B2 0%, #00a898 100%);
  padding: 60rpx 36rpx 36rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.home-greeting {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.home-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 6rpx;
}

.risk-badge {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.risk-badge.risk-low    { background: #f6ffed; color: #52c41a; }
.risk-badge.risk-medium { background: #fffbe6; color: #faad14; }
.risk-badge.risk-high   { background: #fff2f0; color: #ff4d4f; }

/* phase card */
.phase-card {
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
}

.phase-card-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.phase-label {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.phase-label.phase-pre   { background: #e6f7ff; color: #1890ff; }
.phase-label.phase-inhos { background: #fff7e6; color: #fa8c16; }
.phase-label.phase-post  { background: #f9f0ff; color: #722ed1; }
.phase-label.phase-home  { background: #f6ffed; color: #52c41a; }

.phase-bar-wrap {
  position: relative;
  display: flex;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.phase-progress-line {
  position: absolute;
  top: 18rpx;
  left: 28rpx;
  right: 28rpx;
  height: 6rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  z-index: 0;
}

.phase-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #00C7B2 0%, #52c41a 100%);
  border-radius: 4rpx;
  transition: width 0.4s;
}

.phase-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  z-index: 1;
}

.phase-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
}

.phase-step-done .phase-dot  { background: #52c41a; }
.phase-step-active .phase-dot { background: #00C7B2; }

.phase-dot-inner {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
}

.phase-check { font-size: 20rpx; color: #fff; }

.phase-name {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: center;
  line-height: 1.3;
}

.phase-step-done .phase-name  { color: #52c41a; }
.phase-step-active .phase-name { color: #00C7B2; font-weight: 600; }

.phase-tip {
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
  background: #E6FBF9;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #00C7B2;
}

/* risk card */
.risk-card {
  margin: 16rpx 24rpx 0;
  padding: 24rpx 28rpx;
}

.risk-card-low    { border-left: 6rpx solid #52c41a; }
.risk-card-medium { border-left: 6rpx solid #faad14; }
.risk-card-high   { border-left: 6rpx solid #ff4d4f; }

.risk-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.risk-card-icon { font-size: 30rpx; }

.risk-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.risk-card-body {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

/* quick grid */
.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 0;
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  padding: 28rpx 12rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.quick-icon-blue   { background: #e6f7ff; }
.quick-icon-green  { background: #f6ffed; }
.quick-icon-orange { background: #fff7e6; }
.quick-icon-purple { background: #f9f0ff; }

.quick-label {
  font-size: 22rpx;
  color: #555;
}

/* info prompt */
.info-prompt {
  margin: 16rpx 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-left: 6rpx solid #faad14;
}

.info-prompt-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.info-prompt-sub {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}

.info-prompt-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* summary */
.summary-card {
  margin: 16rpx 24rpx 0;
  padding: 28rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.summary-row {
  display: flex;
  align-items: center;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.summary-key {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f0f0;
}

.text-danger   { color: #ff4d4f; }
.text-warning  { color: #faad14; }
.text-success  { color: #52c41a; }
.text-primary  { color: #00C7B2; }
.text-secondary{ color: #999; }
