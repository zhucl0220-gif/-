/* pages/action/index.wxss — 阿福管家风·营养行动 */

.root { min-height: 100vh; background: #F8F9FA; padding-bottom: 40rpx; }

/* ── Tab 导航 ─────────────────────────────────────────── */
.tab-bar { display: flex; background: #fff; border-bottom: 2rpx solid #F0F0F0; position: sticky; top: 0; z-index: 10; }
.tab-item { flex: 1; text-align: center; padding: 28rpx 0; font-size: 28rpx; color: #999; }
.tab-active { color: #00C7B2; font-weight: 700; border-bottom: 4rpx solid #00C7B2; }
.tab-body { height: calc(100vh - 104rpx); }

/* ── 阶段提示条 ───────────────────────────────────────── */
.phase-tip {
  display: flex; align-items: center; gap: 12rpx;
  margin: 24rpx 24rpx 0;
  background: #E6FBF9; border-radius: 16rpx; padding: 18rpx 24rpx;
}
.phase-tip-icon { font-size: 28rpx; }
.phase-tip-text { font-size: 24rpx; color: #00C7B2; font-weight: 600; }

/* ── MP-17: 半圆环进度区 ────────────────────────────────── */
.ring-row {
  display: flex; justify-content: space-around;
  margin: 20rpx 24rpx 0;
  background: #fff; border-radius: 20rpx;
  padding: 32rpx 16rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.ring-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.ring-wrap { position: relative; display: flex; align-items: center; justify-content: center; }
.ring-canvas { display: block; }
.ring-center {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  display: flex; flex-direction: column; align-items: center; line-height: 1.2;
}
.ring-pct { font-size: 22rpx; font-weight: 800; color: #1A1A1A; }
.ring-val  { font-size: 18rpx; color: #AAA; }
.ring-label { font-size: 26rpx; font-weight: 700; color: #333; }
.ring-sub   { font-size: 20rpx; color: #AAA; }

/* ── 目标卡片 ───────────────────────────────────────────── */
.card {
  margin: 16rpx 24rpx 0;
  background: #fff; border-radius: 20rpx; padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.card-title-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.card-dot { width: 8rpx; height: 28rpx; background: #00C7B2; border-radius: 4rpx; }
.card-title { font-size: 30rpx; font-weight: 700; color: #1A1A1A; }
.goal-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0; border-top: 2rpx solid #F5F5F5;
}
.goal-left { flex: 1; }
.goal-label { font-size: 28rpx; font-weight: 600; color: #333; }
.goal-sub { font-size: 22rpx; color: #AAA; margin-top: 4rpx; }
.goal-tag {
  background: #E6FBF9; color: #00C7B2;
  font-size: 22rpx; font-weight: 700;
  padding: 6rpx 20rpx; border-radius: 20rpx; white-space: nowrap; flex-shrink: 0;
}

/* ── MP-20: 7 天周历 ──────────────────────────────────────── */
.week-card {
  margin: 24rpx 24rpx 0;
  background: #fff; border-radius: 20rpx; padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.week-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 20rpx; }
.week-title { font-size: 30rpx; font-weight: 700; color: #1A1A1A; }
.week-count { font-size: 26rpx; color: #00C7B2; font-weight: 700; }
.week-row { display: flex; justify-content: space-between; }
.week-col { display: flex; flex-direction: column; align-items: center; gap: 8rpx; flex: 1; }
.week-date-num { font-size: 26rpx; color: #999; font-weight: 600; }
.week-today { color: #00C7B2; }
.week-dot-wrap { display: flex; align-items: center; justify-content: center; }
.week-dot {
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: #E8E8E8;
}
.week-dot-done  { background: #00C7B2; }
.week-dot-today { box-shadow: 0 0 0 4rpx rgba(0,199,178,0.2); }
.week-wd { font-size: 20rpx; color: #BBB; }

/* ── MP-18: 四餐入口网格 ────────────────────────────────── */
.meal-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16rpx; margin: 16rpx 24rpx 0;
}
.meal-btn {
  background: #fff; border-radius: 20rpx; padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  position: relative;
}
.meal-btn-done { background: #F0FBF9; border: 2rpx solid #00C7B2; }
.meal-btn-icon  { font-size: 48rpx; }
.meal-btn-name  { font-size: 28rpx; font-weight: 700; color: #333; }
.meal-btn-cal   { font-size: 22rpx; color: #AAA; }
.meal-btn-plus {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #00C7B2; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 700; line-height: 1;
}
.meal-btn-check {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #00C7B2; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 700;
}

/* 备注區 */
.diary-note {
  width: 100%; min-height: 120rpx;
  border: 2rpx solid #E8E8E8; border-radius: 12rpx;
  padding: 16rpx 20rpx; font-size: 26rpx; box-sizing: border-box;
  background: #FAFAFA; color: #333;
}

/* ── 操作按钮行 ─────────────────────────────────────────── */
.action-row { margin: 20rpx 24rpx 0; }
.mb40 { margin-bottom: 40rpx; }
.btn-primary {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: linear-gradient(90deg, #00C7B2 0%, #00a898 100%);
  color: #fff; font-size: 30rpx; font-weight: 700; border: none;
  box-shadow: 0 8rpx 24rpx rgba(0,199,178,0.35);
}

/* ── MP-22: 免疫抑制剂警示 + MP-21: 药品列表 ────────────────── */
.immu-alert {
  margin: 24rpx 24rpx 16rpx;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFF0D4 100%);
  border-radius: 20rpx; padding: 24rpx 28rpx;
  border-left: 8rpx solid #FF9900;
}
.immu-alert-row { display: flex; align-items: flex-start; gap: 16rpx; }
.immu-warn-icon { font-size: 40rpx; flex-shrink: 0; }
.immu-alert-title { font-size: 28rpx; font-weight: 700; color: #D46B08; margin-bottom: 8rpx; }
.immu-alert-text  { font-size: 24rpx; color: #8C5800; line-height: 1.7; }

.med-item {
  padding: 24rpx 0;
  border-top: 2rpx solid #F5F5F5;
}
.med-item-warn { background: #FFFBF0; margin: 0 -28rpx; padding: 20rpx 28rpx; }
.med-item-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.med-name-row { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.med-name { font-size: 30rpx; font-weight: 700; color: #1A1A1A; }
.med-warn-badge {
  background: #FFF7E6; color: #D46B08;
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 14rpx;
  border: 2rpx solid #FFD591;
}
.med-status-tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; flex-shrink: 0; }
.tag-taken   { background: #F6FFED; color: #52C41A; border: 2rpx solid #B7EB8F; }
.tag-pending { background: #FFF7E6; color: #FA8C16; border: 2rpx solid #FFD591; }
.med-meta { display: flex; gap: 24rpx; margin-bottom: 10rpx; }
.med-meta-item { font-size: 24rpx; color: #888; }
.med-tip-box {
  background: #FFF7E6; border-radius: 12rpx; padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
}
.med-tip-text { font-size: 22rpx; color: #8C5800; line-height: 1.6; }
.med-action-row { margin-top: 8rpx; }
.btn-med-taken {
  height: 72rpx; border-radius: 36rpx;
  background: linear-gradient(90deg, #52C41A, #40a116);
  color: #fff; font-size: 28rpx; font-weight: 700; border: none;
  box-shadow: 0 4rpx 12rpx rgba(82,196,26,0.3);
}
.med-done-text { font-size: 26rpx; color: #52C41A; font-weight: 600; padding: 12rpx 0; }

/* 注意事项 */
.tip-row { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 16rpx; }
.tip-index {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #E6FBF9; color: #00C7B2;
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.tip-text { font-size: 24rpx; color: #555; line-height: 1.8; flex: 1; }

/* ── OCR 拍照识别区 ────────────────────────────────────── */
.ocr-area {
  background: #F8FFFE; border-radius: 16rpx;
  border: 2rpx dashed #B2EDE8;
  padding: 20rpx 20rpx 16rpx;
  margin-bottom: 20rpx;
}
.ocr-btns {
  display: flex; gap: 16rpx; margin-bottom: 14rpx;
}
.ocr-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 8rpx; height: 72rpx; border-radius: 14rpx;
  border: 2rpx solid #00C7B2; color: #00C7B2;
  font-size: 26rpx; font-weight: 600; background: #fff;
}
.ocr-btn-icon { font-size: 30rpx; }
.ocr-btn-text { font-size: 26rpx; }
.ocr-placeholder {
  text-align: center; padding: 16rpx 0;
}
.ocr-placeholder-text { font-size: 24rpx; color: #BBB; }
.ocr-preview-wrap { width: 100%; border-radius: 12rpx; overflow: hidden; }
.ocr-preview { width: 100%; display: block; border-radius: 12rpx; }
.ocr-loading {
  display: flex; align-items: center; justify-content: center;
  padding: 12rpx 0;
}
.ocr-loading-text { font-size: 24rpx; color: #888; }
.ocr-result-tip {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 10rpx; padding: 10rpx 16rpx;
  background: #F6FFED; border-radius: 10rpx;
  border-left: 4rpx solid #52C41A;
  font-size: 24rpx; color: #389E0D;
}
.ocr-result-error {
  background: #FFF2F0; border-left-color: #FF4D4F; color: #CF1322;
}
.ocr-retry-text {
  font-size: 24rpx; color: #00C7B2; font-weight: 600;
  padding: 4rpx 12rpx; border: 2rpx solid #00C7B2; border-radius: 10rpx;
}

/* ── MP-18: 半屏抓屉弹窗 ───────────────────────────────── */
.drawer-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.45); z-index: 100;
}
.drawer {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
}
.drawer-show { transform: translateY(0); }
.drawer-handle {
  width: 64rpx; height: 8rpx; border-radius: 4rpx;
  background: #E0E0E0; margin: 16rpx auto 0;
}
.drawer-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 32rpx 12rpx;
}
.drawer-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.drawer-close  { font-size: 44rpx; color: #BBB; padding: 0 8rpx; line-height: 1; }
.drawer-body { padding: 12rpx 32rpx 32rpx; }
.drawer-field { margin-bottom: 20rpx; }
.drawer-field.half { flex: 1; }
.drawer-row2 { display: flex; gap: 20rpx; margin-bottom: 20rpx; }
.drawer-label { font-size: 26rpx; font-weight: 600; color: #555; margin-bottom: 10rpx; }
.drawer-textarea {
  width: 100%; min-height: 120rpx;
  border: 2rpx solid #E8E8E8; border-radius: 14rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; box-sizing: border-box;
  background: #FAFAFA; color: #333;
}
.drawer-input {
  width: 100%; height: 72rpx;
  border: 2rpx solid #E8E8E8; border-radius: 14rpx;
  padding: 0 20rpx; font-size: 30rpx; box-sizing: border-box;
  background: #FAFAFA; color: #333;
}
.drawer-submit { margin-top: 8rpx; }
.tab-bar { display: flex; background: #fff; border-bottom: 2rpx solid #f0f0f0; }
.tab-item { flex: 1; text-align: center; padding: 28rpx 0; font-size: 28rpx; color: #888; }
.tab-active { color: #00C7B2; border-bottom: 4rpx solid #00C7B2; font-weight: 700; }
.tab-body { height: calc(100vh - 108rpx); }
.mx24 { margin-left: 24rpx; margin-right: 24rpx; }
.mt24 { margin-top: 24rpx; }
.mt16 { margin-top: 16rpx; }
.mt12 { margin-top: 12rpx; }
.mt8  { margin-top: 8rpx; }
.mt20 { margin-top: 20rpx; }
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.card-title { font-size: 30rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 20rpx; }
.phase-tip-banner { display: flex; align-items: center; gap: 12rpx; background: #e6f7ff; border-radius: 16rpx; padding: 18rpx 24rpx; }
.phase-tip-icon { font-size: 28rpx; }
.phase-tip-text { font-size: 24rpx; color: #00C7B2; }
.goal-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 16rpx 0; border-top: 2rpx solid #f5f5f5; }
.goal-label { font-size: 28rpx; color: #333; font-weight: 600; }
.goal-sub { font-size: 22rpx; color: #aaa; margin-top: 4rpx; display: block; }
.goal-target { font-size: 28rpx; color: #00C7B2; font-weight: 700; }
.progress-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.progress-label { font-size: 24rpx; color: #666; width: 96rpx; flex-shrink: 0; }
.progress-wrap { flex: 1; display: flex; align-items: center; gap: 12rpx; }
.progress-bar-bg { flex: 1; height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.4s; min-width: 4rpx; }
.progress-pct { font-size: 22rpx; color: #999; width: 60rpx; text-align: right; }
.meal-section { border-top: 2rpx solid #f5f5f5; }
.meal-header { display: flex; align-items: center; padding: 20rpx 0; gap: 12rpx; }
.meal-icon { font-size: 32rpx; }
.meal-name { font-size: 28rpx; color: #333; font-weight: 600; flex: 1; }
.meal-cal { font-size: 24rpx; color: #00C7B2; }
.meal-arrow { font-size: 24rpx; color: #bbb; margin-left: 8rpx; }
.meal-body { padding-bottom: 20rpx; }
.meal-input { width: 100%; border: 2rpx solid #eee; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 26rpx; box-sizing: border-box; color: #333; background: #fafafa; }
.meal-cal-row { display: flex; align-items: center; gap: 12rpx; margin-top: 12rpx; }
.meal-cal-label { font-size: 24rpx; color: #888; flex-shrink: 0; }
.meal-cal-input { flex: 1; border: 2rpx solid #eee; border-radius: 12rpx; padding: 12rpx 16rpx; font-size: 26rpx; }
.diary-note-row { margin-top: 24rpx; }
.diary-note-label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; display: block; }
.diary-note-input { width: 100%; min-height: 120rpx; border: 2rpx solid #eee; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 26rpx; box-sizing: border-box; background: #fafafa; }
