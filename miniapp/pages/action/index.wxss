.week-bar { display: flex; justify-content: space-between; padding: 8rpx 0; }
.week-day { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.week-dot { width: 48rpx; height: 48rpx; border-radius: 50%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: #fff; }
.week-dot-done { background: #52c41a; }
.week-day-label { font-size: 22rpx; color: #aaa; }
.med-alert-box { background: #fff7e6; border-radius: 16rpx; padding: 20rpx 24rpx; display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 20rpx; }
.med-alert-icon { font-size: 40rpx; }
.med-alert-title { font-size: 28rpx; font-weight: 700; color: #fa8c16; margin-bottom: 8rpx; }
.med-alert-tip { font-size: 24rpx; color: #a17040; line-height: 1.6; }
.med-item { border-top: 2rpx solid #f5f5f5; padding: 20rpx 0; }
.med-item-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.med-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.med-status-tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; }
.tag-green { background: #f6ffed; color: #52c41a; border: 2rpx solid #b7eb8f; }
.tag-orange { background: #fff7e6; color: #fa8c16; border: 2rpx solid #ffd591; }
.med-detail-row { display: flex; gap: 24rpx; }
.med-detail { font-size: 24rpx; color: #888; }
.btn-check-med { height: 68rpx; border-radius: 34rpx; background: linear-gradient(90deg,#52c41a,#73d13d); color: #fff; font-size: 26rpx; font-weight: 700; border: none; }
.med-check-done { font-size: 24rpx; color: #52c41a; margin-top: 10rpx; }
.tip-item { display: flex; gap: 12rpx; margin-bottom: 14rpx; }
.tip-num { font-size: 24rpx; color: #00C7B2; font-weight: 700; flex-shrink: 0; }
.tip-text { font-size: 24rpx; color: #555; line-height: 1.7; }
