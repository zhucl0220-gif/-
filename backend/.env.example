# 复制为 .env 并填写真实值
APP_NAME=肝移植患者营养全流程管理系统
DEBUG=True

DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/liver_nutrition

SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

OCR_ENGINE=paddleocr

# WebSearch：mock（开发）| serper（推荐）| google
SEARCH_ENGINE=mock
SERPER_API_KEY=your-serper-key-here
GOOGLE_CSE_API_KEY=your-google-cse-key-here
GOOGLE_CSE_ID=your-cse-id-here

# Python 沙箱：exec（开发）| docker（生产）
SANDBOX_MODE=exec
SANDBOX_TIMEOUT_SEC=30
SANDBOX_DOCKER_IMAGE=python:3.12-slim

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
